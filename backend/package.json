{
  "name": "sistem-buku-tamu-backend",
  "version": "1.0.0",
  "description": "Backend service for Sistem Buku Tamu",
  "main": "index.js",
  "scripts": {
    "dev": "node --loader tsx --watch services/server.ts",
    "build": "tsc",
    "start": "node dist/services/server.js",
    "migration:run": "tsx migrations/runMigrations.ts",
    "migration:single": "tsx migrations/runSingleMigration.ts",
    "seed": "tsx seeds/runSeeds.ts"
  },
  "dependencies": {
    "mysql2": "^3.6.0",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.17",
    "@types/cors": "^2.8.13",
    "typescript": "^5.0.0",
    "tsx": "^4.0.0"
  },
  "keywords": [
    "backend",
    "api",
    "mysql",
    "typescript"
  ],

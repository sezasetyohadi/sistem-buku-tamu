{
  "name": "sistem-buku-tamu",
  "version": "1.0.0",
  "description": "Sistem Buku Tamu DISNAKERTRANS Jawa Tengah",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "migration:run": "cd backend && npm run migration:run",
    "migration:single": "cd backend && npm run migration:single",
    "seed": "cd backend && npm run seed",
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "cd backend && npm start",
    "start:frontend": "cd frontend && npm start"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "sistem-buku-tamu",
    "guest-book",
    "survey",
    "nextjs",
    "express",
    "mysql"
  ],
  "author": "DISNAKERTRANS Jawa Tengah",
  "license": "MIT"
}
